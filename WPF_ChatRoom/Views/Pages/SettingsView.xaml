<UserControl x:Class="WPF_ChatRoom.Views.Pages.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF_ChatRoom.Views.Pages"
             xmlns:cc = "clr-namespace:WPF_ChatRoom.CustomControl"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border CornerRadius="20">
        <Grid ShowGridLines="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            
            <!--Server-->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="150"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="5*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.ColumnSpan="99" Text="Server" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                
                <TextBlock Grid.Row="1" Text="IP:" Width="20" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ServerIP}" Width="150" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                
                <TextBlock Grid.Row="2" Text="Prot:" Width="30" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding ServerPort}" Width="150" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                
                <TextBlock Grid.Row="3" Text="MaxNumber:" Width="78" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding ServerMaxNumber}" Width="150" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                
                <cc:CustomButton Grid.Row="4" Grid.Column="1" Width="80" Height="30" Content="创建服务端" Command="{Binding CreateServerCommand}" HorizontalAlignment="Left" VerticalAlignment="Top" Style="{StaticResource CustomButtonStyle}"></cc:CustomButton>
            </Grid>
            
            <Line Grid.RowSpan="99" Grid.Column="1" X1="10" Y1="0" X2="10" Y2="1000" Stroke="Black" StrokeThickness="2" StrokeDashArray="4 2"/>
            
            <!--Client-->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="150"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="5*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.ColumnSpan="99" Text="Client" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                
                <TextBlock Grid.Row="1" Text="IP:" Width="20" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RemoteServerIP}" Width="150" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                
                <TextBlock Grid.Row="2" Text="Prot:" Width="30" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RemoteServerProt}" Width="150" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                
                <cc:CustomButton Grid.Row="4" Grid.Column="1" Width="80" Height="30" Content="连接至服务器" Command="{Binding ClientConnectCommand}" HorizontalAlignment="Left" VerticalAlignment="Top" Style="{StaticResource CustomButtonStyle}"/>
            </Grid>
            
            
            
        </Grid>
    </Border>
</UserControl>
